<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_CONFIG_CACHE" value="bootstrap/cache/testing-config.php"/>
        <env name="APP_ROUTES_CACHE" value="bootstrap/cache/testing-routes.php"/>
        <env name="APP_EVENTS_CACHE" value="bootstrap/cache/testing-events.php"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="MAIL_FROM_ADDRESS" value="admin@chapungart.com"/>
        <env name="ADMIN_EMAILS" value="admin@chapungart.com"/>
        <env name="INFO_EMAIL" value="info@chapungart.com"/>
        <env name="GALLERY_EMAIL" value="gallery@chapungart.com"/>
        <env name="NEWS_EMAIL" value="news@chapungart.com"/>
        <env name="MEDIA_EMAIL" value="media@chapungart.com"/>
        <env name="SUPPORT_EMAIL" value="support@chapungart.com"/>
        <env name="FINANCE_EMAIL" value="finance@chapungart.com"/>
        <env name="CONTACT_EMAIL" value="contact@chapungart.com"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
